# =============================================================================
# StudyBot — environment configuration
# =============================================================================
# Local development defaults to LOCAL backends — no AWS credentials required.
# To deploy on AWS, flip backends to bedrock / s3 / dynamodb / bedrock_kb.

# ----- AI backend -----
# Options: bedrock | local
# - bedrock: real Amazon Bedrock InvokeModel + KB retrieve-and-generate
# - local:   stub responses, no AWS call. Use for local development.
AI_BACKEND=local
AI_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
AWS_REGION=ap-southeast-1

# ----- Object storage backend (for uploaded PDFs) -----
# Options: s3 | local
STORAGE_BACKEND=local
STORAGE_BUCKET=                       # required when STORAGE_BACKEND=s3
STORAGE_LOCAL_DIR=./_data/uploads     # used when STORAGE_BACKEND=local

# ----- User state DB backend -----
# Options: dynamodb | postgres | sqlite
# Pick ONE for production. SQLite is local-dev only.
USERSTORE_BACKEND=sqlite
USERSTORE_TABLE=studybot-users        # required when USERSTORE_BACKEND=dynamodb
USERSTORE_POSTGRES_URL=               # required when USERSTORE_BACKEND=postgres (e.g. postgresql://user:pw@host:5432/db)
USERSTORE_SQLITE_PATH=./_data/users.db

# ----- Vector store backend (for KB chunks) -----
# Options: bedrock_kb | local
# - bedrock_kb: Bedrock Knowledge Base — you choose OpenSearch Serverless / S3 Vectors / Aurora pgvector
#               when creating the KB in AWS console
# - local:      simple in-memory keyword index (good enough for local testing)
VECTOR_BACKEND=local
VECTOR_BEDROCK_KB_ID=                 # required when VECTOR_BACKEND=bedrock_kb

# ----- Identity -----
# The app expects an `X-User-Id` header on every request.
# How you populate that header is YOUR design decision:
#   - Cognito User Pool → API Gateway authorizer decodes JWT, injects header
#   - Hardcoded test user → set DEFAULT_USER_ID, frontend sends it
#   - Signed URL → embed user_id in signed payload
DEFAULT_USER_ID=test-user-001

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Frontend serving (split deploy?) -----
# When SERVE_FRONTEND=true, the backend serves frontend/index.html at /.
# Set SERVE_FRONTEND=false if you deploy frontend separately to CloudFront+S3,
# Amplify, ALB+S3, or anywhere else. The frontend will then need its API_BASE
# set to point to this backend URL.
SERVE_FRONTEND=true

# ----- CORS -----
# Comma-separated list of allowed origins. Use '*' for hackathon (permissive),
# or pin to your frontend URL like 'https://d123.cloudfront.net' in production.
CORS_ORIGINS=*

# ----- Extra DB backends (optional — require requirements-optional.txt) -----
# To use DocumentDB or RDS MySQL, set USERSTORE_BACKEND accordingly AND install
# the extra deps:  pip install -r requirements-optional.txt
#
# Options: dynamodb | postgres | sqlite | documentdb | mysql
USERSTORE_MONGO_URL=                         # for documentdb (DocumentDB or MongoDB Atlas)
USERSTORE_MONGO_DB=studybot                   # database name on the MongoDB instance
USERSTORE_MONGO_TLS_CA=                      # path to RDS CA bundle for DocumentDB TLS verify
USERSTORE_MYSQL_URL=                         # for mysql (mysql://user:pw@host:3306/db)
